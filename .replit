modules = ["python-3.11"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["glibcLocales", "xcodebuild", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Lead Scraper"

[[workflows.workflow]]
name = "Lead Scraper"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py --pages 1 --town Guildford"

[workflows.workflow.metadata]
outputType = "console"
