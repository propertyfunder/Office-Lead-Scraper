modules = ["python-3.11"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["glibcLocales", "xcodebuild", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Dashboard"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "CH Enrichment"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Surgical Enrichment"

[[workflows.workflow]]
name = "Dashboard"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python app.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "CH Enrichment"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python ch_enrich.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Surgical Enrichment"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python run_surgical_enrichment.py --stats"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80
