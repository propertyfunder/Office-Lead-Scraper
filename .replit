modules = ["python-3.11"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["chromium", "gitFull", "glibcLocales", "playwright-driver", "xcodebuild", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Dashboard"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "CH Enrichment"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Surgical Enrichment"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Lead Cleanup"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Email Rescrape"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "JS Email Scrape"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Website Discovery Test"

[[workflows.workflow]]
name = "Dashboard"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python app.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "CH Enrichment"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python ch_enrich.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Surgical Enrichment"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python run_surgical_enrichment.py --stats"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Lead Cleanup"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python run_cleanup.py --stats"

[[workflows.workflow]]
name = "Email Rescrape"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python run_email_rescrape.py --run --retry-previous --batch-size 5"

[[workflows.workflow]]
name = "JS Email Scrape"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python run_js_scrape.py --run --limit 500"

[[workflows.workflow]]
name = "Website Discovery Test"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python run_website_discovery_v2.py"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "vm"
run = ["bash", "deploy.sh"]
